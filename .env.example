# ============================================================
# CONK 환경변수 템플릿
# .env.local 또는 .env.prod 파일을 이 파일 기반으로 작성하세요.
#
# 로컬 개발: cp .env.example .env.local  → 값 채우기
# 배포:      cp .env.example .env.prod   → 실제 프로덕션 값으로 교체
#
# 사용법:
#   docker-compose --env-file .env.local up -d          # 개발
#   docker-compose --env-file .env.local up -d --build  # 코드 변경 후 재빌드
# ============================================================

# ===== Database (공통 인증) =====
DB_ROOT_PASSWORD=
DB_USERNAME=
DB_PASSWORD=

# ===== Per-service DB URLs (Docker 내부 hostname 사용) =====
MEMBER_DB_URL=jdbc:mariadb://member-db:3306/member_db?useSSL=false&serverTimezone=Asia/Seoul
ORDER_DB_URL=jdbc:mariadb://order-db:3306/order_db?useSSL=false&serverTimezone=Asia/Seoul
WMS_DB_URL=jdbc:mariadb://wms-db:3306/wms_db?useSSL=false&serverTimezone=Asia/Seoul
INTEGRATION_DB_URL=jdbc:mariadb://integration-db:3306/integration_db?useSSL=false&serverTimezone=Asia/Seoul
NOTIFICATION_DB_URL=jdbc:mariadb://notification-db:3306/notification_db?useSSL=false&serverTimezone=Asia/Seoul

# ===== Kafka =====
SPRING_KAFKA_BOOTSTRAP_SERVERS=kafka:9092

# ===== Redis =====
SPRING_DATA_REDIS_HOST=redis
SPRING_DATA_REDIS_PORT=6379

# ===== Service URL =====
MEMBER_SERVICE_URL=http://member-service:8080

# ===== JWT (member-service) =====
# Base64 인코딩된 256비트(32바이트) 이상 키 필요 (JJWT 요구사항)
# 키 생성 명령어: openssl rand -base64 48
JWT_SECRET=
JWT_EXPIRATION=3600000
JWT_REFRESH_EXPIRATION=604800000

# ===== Shopify =====
# store-name, access-token 은 사용자가 UI에서 입력 → DB 저장 (env 불필요)
# api-version 은 application.yml 고정값으로 관리 (수정 불필요)

# ===== EasyPost (개발자가 세팅) =====
EASYPOST_API_KEY=
EASYPOST_BASE_URL=https://api.easypost.com

# ===== Frontend =====
# 배포 시 vite build --mode prod 에 번들로 삽입됨 (빌드 시점에 결정)
# 개발 Docker에서는 Vite proxy(API_PROXY_TARGET=http://api-gateway)가 처리하므로 미사용
VITE_API_BASE_URL=
