# =============================================================================
# CONK Platform — 환경변수 템플릿
# =============================================================================
# 사용법:
#   로컬 개발 : cp .env.example .env.local  → 값 채우기  (절대 Git 커밋 금지)
#   Docker    : docker-compose --env-file .env.local up -d
#   CI/CD     : 파이프라인 시크릿으로 개별 변수 오버라이드
#   K8s       : ConfigMap(비민감) + Sealed Secrets / External Secrets(민감)으로 주입
# =============================================================================

# -----------------------------------------------------------------------------
# [GitOps] 컨테이너 이미지 태그 — ArgoCD/Flux Image Updater가 이 값을 갱신하여 배포를 트리거
# -----------------------------------------------------------------------------
IMAGE_TAG_MEMBER=latest
IMAGE_TAG_ORDER=latest
IMAGE_TAG_WMS=latest
IMAGE_TAG_INTEGRATION=latest
IMAGE_TAG_NOTIFICATION=latest
IMAGE_TAG_BATCH=latest
IMAGE_TAG_FRONTEND=latest

# -----------------------------------------------------------------------------
# [배포 환경] Spring 프로파일
# -----------------------------------------------------------------------------
# local | dev | prod
SPRING_PROFILES_ACTIVE=local

# =============================================================================
# DATABASE  ⚠️ K8s Secret 필수
# =============================================================================
# ⚠️ 경고: DB 비밀번호는 반드시 K8s Sealed Secrets / External Secrets Operator /
#          HashiCorp Vault를 통해 주입해야 합니다. 절대 평문으로 Git에 커밋하지 마세요.
# ⚠️ 비밀번호 생성 예시: openssl rand -base64 24

DB_ROOT_PASSWORD=        # [CI/CD 오버라이드 필수] MariaDB root 비밀번호
DB_USERNAME=root         # 로컬 개발 기본값
DB_PASSWORD=             # [CI/CD 오버라이드 필수]

# 서비스별 DB 연결 URL (Docker 내부 hostname 사용)
MEMBER_DB_URL=jdbc:mariadb://member-db:3306/member_db?useSSL=false&serverTimezone=Asia/Seoul
ORDER_DB_URL=jdbc:mariadb://order-db:3306/order_db?useSSL=false&serverTimezone=Asia/Seoul
WMS_DB_URL=jdbc:mariadb://wms-db:3306/wms_db?useSSL=false&serverTimezone=Asia/Seoul
INTEGRATION_DB_URL=jdbc:mariadb://integration-db:3306/integration_db?useSSL=false&serverTimezone=Asia/Seoul
NOTIFICATION_DB_URL=jdbc:mariadb://notification-db:3306/notification_db?useSSL=false&serverTimezone=Asia/Seoul
BATCH_DB_URL=jdbc:mariadb://batch-db:3306/batch_db?useSSL=false&serverTimezone=Asia/Seoul

# Batch 서비스 전용 — WMS DB 읽기 전용 복제본 (wms-read-db)
WMS_READ_DB_URL=jdbc:mariadb://wms-read-db:3306/wms_db?useSSL=false&serverTimezone=Asia/Seoul

# =============================================================================
# KAFKA
# =============================================================================
# Docker: kafka:9092 (내부 브로커) | 로컬 직접 실행: localhost:9094
SPRING_KAFKA_BOOTSTRAP_SERVERS=kafka:9092

# WMS 서비스 Kafka 소비자 그룹
KAFKA_CONSUMER_GROUP_ID=wms-billing

# Notification 서비스 Kafka 소비자 그룹
NOTIFICATION_KAFKA_CONSUMER_GROUP_ID=notification-group

# Kafka 토픽명
APP_KAFKA_TOPIC_BILLING_MONTHLY_RESULT=billing.monthly.result.v1

# =============================================================================
# REDIS
# =============================================================================
# Docker: redis | 로컬 직접 실행: localhost
SPRING_DATA_REDIS_HOST=redis
SPRING_DATA_REDIS_PORT=6379

# =============================================================================
# SERVICE URLs — 마이크로서비스 간 내부 통신
# =============================================================================
# Docker Compose : http://<서비스명>:8080  (docker-compose 서비스명 기반 DNS)
# K8s 클러스터   : http://<svc-name>.<namespace>.svc.cluster.local:8080
#                  (K8s Service DNS가 자동 해석 — 동일 namespace면 단축형 사용 가능)

MEMBER_SERVICE_URL=http://member-service:8080
ORDER_SERVICE_URL=http://order-service:8080
WMS_SERVICE_URL=http://wms-service:8080       # order / batch / member(warehouse) 공통 사용
INTEGRATION_SERVICE_URL=http://integration-service:8080
NOTIFICATION_SERVICE_URL=http://notification-service:8080
WAREHOUSE_SERVICE_URL=http://wms-service:8080 # member → wms 창고 조회 전용 alias

# WMS 스텁 클라이언트 활성화 여부 (로컬 단독 테스트: true | 통합 환경: false)
WMS_STUB_CLIENTS_ENABLED=false

# =============================================================================
# SECURITY / JWT  ⚠️ K8s Secret 필수
# =============================================================================
# ⚠️ 경고: JWT_SECRET은 반드시 K8s Secret으로 주입해야 합니다.
#          최소 32바이트(256비트) 이상의 Base64 인코딩 값을 사용하세요.
#          키 생성: openssl rand -base64 48
JWT_SECRET=                       # [CI/CD 오버라이드 필수] Base64 인코딩 서명 키
JWT_EXPIRATION=3600000            # Access Token 만료 (ms) — 기본 1시간
JWT_REFRESH_EXPIRATION=604800000  # Refresh Token 만료 (ms) — 기본 7일

# =============================================================================
# EXTERNAL APIs  ⚠️ K8s Secret 필수
# =============================================================================
# ⚠️ 경고: 아래 외부 API 키들은 K8s Secret 또는 HashiCorp Vault를 통해 주입해야 합니다.
#          절대 평문으로 저장하거나 Git에 커밋하지 마세요.

# --- EasyPost (배송 라벨 생성 — integration-service) ---
EASYPOST_API_KEY=                          # [CI/CD 오버라이드 필수] EasyPost API Key
EASYPOST_BASE_URL=https://api.easypost.com

# --- Shopify (주문 연동 — integration-service) ---
# store-name / access-token은 테넌트별로 UI에서 입력 → DB 저장 (환경변수 불필요)
# API 버전만 환경변수로 관리 (업그레이드 시 재빌드 없이 교체 가능)
SHOPIFY_API_VERSION=2025-01

# =============================================================================
# EMAIL — member-service (비밀번호 설정 메일 발송)  ⚠️ K8s Secret 필수
# =============================================================================
# ⚠️ 경고: MAIL_PASSWORD(Gmail 앱 비밀번호 등)는 K8s Secret으로 주입하세요.
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=                             # [CI/CD 오버라이드 필수] SMTP 계정
MAIL_PASSWORD=                             # [CI/CD 오버라이드 필수] SMTP 앱 비밀번호

# 이메일 본문 브랜딩 (프로덕션에서도 동일 값 사용 가능)
MAIL_FROM_NAME=CONK Fulfillment Platform
MAIL_SERVICE_NAME=CONK

# 이메일 내 링크 URL (프로덕션: 실제 도메인으로 교체)
MAIL_LOGIN_URL=http://localhost:3000/login
MAIL_SETUP_BASE_URL=http://localhost:3000/member/setup-password

# =============================================================================
# BATCH SERVICE — 월별 청구 스케줄러
# =============================================================================
# 로컬/개발에서는 false, 프로덕션 배포 시 true로 활성화
APP_BILLING_SCHEDULING_ENABLED=false
APP_BILLING_SCHEDULING_ZONE=Asia/Seoul
APP_BILLING_SCHEDULING_DAILY_BIN_SNAPSHOT_CRON=0 0 6 * * *   # 매일 06:00
APP_BILLING_SCHEDULING_MONTHLY_BILLING_CRON=0 10 6 1 * *     # 매월 1일 06:10

# =============================================================================
# NOTIFICATION SERVICE
# =============================================================================
# SSE 연결 유지 시간 (ms) — 기본 30분 (1800000ms)
NOTIFICATION_SSE_TIMEOUT=1800000

# =============================================================================
# FRONTEND
# =============================================================================
# Vite 빌드 시 번들에 삽입되므로 런타임 변경 불가.
# Docker build-arg(ARG VITE_API_BASE_URL)로도 전달됩니다.
# 로컬 개발: http://localhost (Nginx 게이트웨이)
# 프로덕션 : https://conk.io (실제 도메인)
VITE_API_BASE_URL=http://localhost

# API 경로 prefix — 프론트엔드가 모든 요청에 붙이는 prefix
# Ingress Nginx Controller(K8s) 또는 nginx-gateway.conf(로컬)에서 이 prefix를 제거 후 백엔드로 라우팅
# → Ingress: nginx.ingress.kubernetes.io/rewrite-target: /$2  (path: /api/v1(/|$)(.*))
# → 로컬 Docker: nginx-gateway.conf의 rewrite ^/api/v1(/.*)$ $1 break 규칙과 반드시 일치해야 함
VITE_API_PREFIX=/api/v1
